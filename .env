# Crypto Trading AI - Environment Configuration

# Application Settings
APP_NAME=CryptoTradingAI
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///data/trading.db
REDIS_URL=redis://localhost:6379/0

# Exchange API Keys (Fill with your actual keys)
# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true

# Bybit
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_SECRET_KEY=your_bybit_secret_key_here
BYBIT_TESTNET=true

# KuCoin
KUCOIN_API_KEY=your_kucoin_api_key_here
KUCOIN_SECRET_KEY=your_kucoin_secret_key_here
KUCOIN_PASSPHRASE=your_kucoin_passphrase_here
KUCOIN_SANDBOX=true

# Trading Settings
DEFAULT_EXCHANGE=binance
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_TIMEFRAME=1h
INITIAL_BALANCE=10000.0
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENT=2.0
TAKE_PROFIT_PERCENT=4.0

# AI Model Settings
DQN_MODEL_PATH=models/dqn_model.pt
TRANSFORMER_MODEL_PATH=models/transformer_model.pt
LSTM_MODEL_PATH=models/lstm_model.pt
ENSEMBLE_MODEL_PATH=models/ensemble_model.pt

# Risk Management
MAX_DAILY_LOSS=5.0
MAX_POSITIONS=3
RISK_PER_TRADE=1.0

# WebSocket
WS_RECONNECT_INTERVAL=5
WS_PING_INTERVAL=30

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_WEBHOOK_URL=your_discord_webhook_url
